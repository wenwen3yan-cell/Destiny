        let currentNumber = null;
        let isShaking = false;

        function shakeNumber() {
            if (isShaking) return;

            isShaking = true;
            const circle = document.getElementById('numberCircle');
            const numberText = document.getElementById('numberText');
            const hint = document.getElementById('hint');
            const card = document.getElementById('destinyCard');

            // 隐藏之前的卡片
            card.classList.remove('show');
            hint.classList.remove('show');

            // 开始摇晃动画
            circle.classList.add('shaking');
            numberText.classList.remove('show');

            // 模拟摇签过程
            let count = 0;
            const maxCount = 8;
            const interval = setInterval(function() {
                const tempNum = Math.floor(Math.random() * 30) + 1;
                numberText.textContent = tempNum;
                numberText.classList.add('show');

                count++;
                if (count >= maxCount) {
                    clearInterval(interval);

                    // 最终结果
                    currentNumber = Math.floor(Math.random() * 30) + 1;
                    numberText.textContent = currentNumber;
                    circle.classList.add('has-number');
                    circle.classList.remove('shaking');

                    // 显示提示
                    hint.textContent = '数字已现，点击查看命理';
                    hint.classList.add('show');

                    isShaking = false;
                }
            }, 80);
        }

        function viewDestiny() {
            const hint = document.getElementById('hint');
            const card = document.getElementById('destinyCard');

            if (!currentNumber) {
                hint.textContent = '请先摇出今日之数';
                hint.classList.add('show');

                // 震动提示
                const circle = document.getElementById('numberCircle');
                circle.style.transform = 'translateX(-5px)';
                setTimeout(function() {
                    circle.style.transform = 'translateX(5px)';
                    setTimeout(function() {
                        circle.style.transform = 'translateX(0)';
                    }, 100);
                }, 100);
                return;
            }

            const data = destinyData[currentNumber - 1];

            // 填充数据
            document.getElementById('cardNumber').textContent = '第 ' + currentNumber + ' · 签';
            document.getElementById('cardTitle').textContent = data.title;
            document.getElementById('sectionColor').textContent = data.color;
            document.getElementById('sectionCareer').textContent = data.career;
            document.getElementById('sectionLove').textContent = data.love;
            document.getElementById('sectionHeart').textContent = data.heart;

            // 显示卡片
            card.classList.remove('show');
            setTimeout(function() {
                card.classList.add('show');
                hint.classList.remove('show');

                // 平滑滚动到卡片
                card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }, 100);
        }

        // 键盘支持
        document.addEventListener('keydown', function(e) {
            if (e.code === 'Space') {
                e.preventDefault();
                shakeNumber();
            } else if (e.code === 'Enter') {
                e.preventDefault();
                viewDestiny();
            }
        });
    </script>
