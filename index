<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>七星曜 · 三十命格签</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #F9F8F6;
            --bg-warm: #F5F2EB;
            --text-primary: #2C2C2C;
            --text-secondary: #5C5C5C;
            --accent-gold: #B76E3A;
            --accent-ochre: #8B5A2B;
            --border-light: rgba(0, 0, 0, 0.05);
            --card-bg: rgba(255, 255, 255, 0.85);
            --shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Noto Sans SC', sans-serif;
            background: linear-gradient(135deg, var(--bg-color) 0%, var(--bg-warm) 100%);
            min-height: 100vh;
            color: var(--text-primary);
            line-height: 1.8;
            overflow-x: hidden;
        }

        .container {
            max-width: 680px;
            margin: 0 auto;
            padding: 40px 20px;
            position: relative;
        }

        /* 顶部标题区 */
        .header {
            text-align: center;
            margin-bottom: 48px;
            position: relative;
        }

        .header::before {
            content: '◆';
            display: block;
            color: var(--accent-gold);
            font-size: 12px;
            margin-bottom: 16px;
            opacity: 0.6;
            letter-spacing: 8px;
        }

        h1 {
            font-family: 'Noto Serif SC', serif;
            font-size: 32px;
            font-weight: 700;
            letter-spacing: 6px;
            margin-bottom: 12px;
            color: var(--text-primary);
        }

        .subtitle {
            font-size: 14px;
            color: var(--text-secondary);
            letter-spacing: 4px;
            font-weight: 300;
        }

        /* 数字显示区 */
        .number-display {
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 48px 0;
            position: relative;
        }

        .number-circle {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            background: var(--card-bg);
            border: 1px solid var(--border-light);
            box-shadow: var(--shadow);
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .number-circle.shaking {
            animation: shake 0.5s ease-in-out;
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0) rotate(0deg); }
            25% { transform: translateX(-8px) rotate(-5deg); }
            75% { transform: translateX(8px) rotate(5deg); }
        }

        .number-text {
            font-family: 'Noto Serif SC', serif;
            font-size: 72px;
            font-weight: 700;
            color: var(--accent-gold);
            opacity: 0;
            transform: scale(0.8);
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .number-text.show {
            opacity: 1;
            transform: scale(1);
        }

        .number-placeholder {
            font-size: 14px;
            color: var(--text-secondary);
            letter-spacing: 2px;
            position: absolute;
        }

        .number-circle.has-number .number-placeholder {
            display: none;
        }

        /* 按钮区 */
        .button-group {
            display: flex;
            gap: 16px;
            justify-content: center;
            margin-bottom: 48px;
        }

        button {
            padding: 14px 32px;
            border: none;
            border-radius: 4px;
            font-family: 'Noto Sans SC', sans-serif;
            font-size: 15px;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .btn-primary {
            background: var(--text-primary);
            color: #fff;
        }

        .btn-primary:hover {
            background: var(--accent-ochre);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(139, 90, 43, 0.2);
        }

        .btn-secondary {
            background: transparent;
            color: var(--text-primary);
            border: 1px solid var(--border-light);
        }

        .btn-secondary:hover {
            background: var(--card-bg);
            border-color: var(--accent-gold);
            color: var(--accent-gold);
        }

        button:active {
            transform: scale(0.98);
        }

        /* 提示信息 */
        .hint {
            text-align: center;
            font-size: 13px;
            color: var(--text-secondary);
            margin-top: -24px;
            margin-bottom: 32px;
            opacity: 0;
            transition: opacity 0.3s ease;
            font-style: italic;
        }

        .hint.show {
            opacity: 1;
        }

        /* 命格卡片 */
        .destiny-card {
            background: var(--card-bg);
            border: 1px solid var(--border-light);
            border-radius: 12px;
            padding: 40px 32px;
            box-shadow: var(--shadow);
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
            display: none;
        }

        .destiny-card.show {
            display: block;
            opacity: 1;
            transform: translateY(0);
        }

        .card-header {
            text-align: center;
            margin-bottom: 32px;
            padding-bottom: 24px;
            border-bottom: 1px solid var(--border-light);
        }

        .card-number {
            font-size: 12px;
            color: var(--text-secondary);
            letter-spacing: 3px;
            margin-bottom: 8px;
        }

        .card-title {
            font-family: 'Noto Serif SC', serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: 4px;
        }

        .card-section {
            margin-bottom: 28px;
            position: relative;
            padding-left: 20px;
        }

        .card-section::before {
            content: '';
            position: absolute;
            left: 0;
            top: 8px;
            width: 4px;
            height: 4px;
            background: var(--accent-gold);
            border-radius: 50%;
        }

        .section-title {
            font-family: 'Noto Serif SC', serif;
            font-size: 15px;
            font-weight: 600;
            color: var(--accent-ochre);
            margin-bottom: 8px;
            letter-spacing: 2px;
        }

        .section-content {
            font-size: 15px;
            color: var(--text-primary);
            line-height: 1.9;
            text-align: justify;
        }

        .heart-seal {
            margin-top: 32px;
            padding: 24px;
            background: linear-gradient(135deg, rgba(183, 110, 58, 0.05) 0%, rgba(139, 90, 43, 0.03) 100%);
            border-radius: 8px;
            border-left: 3px solid var(--accent-gold);
            position: relative;
        }

        .heart-seal .section-title {
            color: var(--accent-gold);
        }

        .heart-seal .section-content {
            font-family: 'Noto Serif SC', serif;
            font-style: italic;
            font-size: 16px;
            color: var(--accent-ochre);
            line-height: 2;
        }

        /* 底部签名 */
        .footer {
            text-align: center;
            margin-top: 48px;
            padding-top: 24px;
            font-size: 13px;
            color: var(--text-secondary);
            letter-spacing: 2px;
            font-style: italic;
            opacity: 0.7;
        }

        .footer::before {
            content: '—';
            display: block;
            margin-bottom: 12px;
            letter-spacing: 8px;
        }

        /* 响应式 */
        @media (max-width: 480px) {
            h1 {
                font-size: 24px;
                letter-spacing: 4px;
            }

            .number-circle {
                width: 120px;
                height: 120px;
            }

            .number-text {
                font-size: 56px;
            }

            .button-group {
                flex-direction: column;
                align-items: center;
            }

            button {
                width: 160px;
            }

            .destiny-card {
                padding: 28px 20px;
            }

            .card-title {
                font-size: 22px;
            }
        }

        /* 装饰元素 */
        .decoration {
            position: fixed;
            pointer-events: none;
            opacity: 0.03;
            font-family: 'Noto Serif SC', serif;
            font-size: 200px;
            z-index: -1;
        }

        .decoration-1 {
            top: -50px;
            right: -30px;
            transform: rotate(15deg);
        }

        .decoration-2 {
            bottom: -30px;
            left: -20px;
            transform: rotate(-10deg);
        }
    </style>
<base target="_blank">
</head>
<body>
