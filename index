            </div>

            <div class="card-section">
                <div class="section-title">情缘 · 渡口</div>
                <div class="section-content" id="sectionLove"></div>
            </div>

            <div class="heart-seal">
                <div class="section-title">心印 · 一言</div>
                <div class="section-content" id="sectionHeart"></div>
            </div>
        </div>

        <footer class="footer">
            命理是镜，你才是光
        </footer>
    </div>

